#!/usr/bin/env sh
# `set -e` is load-bearing: without it, a Layer 0 exit-1 prints "BLOCKED"
# but doesn't actually abort the hook (sh keeps running after non-zero exits
# unless errexit is on). The hook then returns the last command's exit code.
set -e

# ─── Multi-window protocol — rebase + migration claim ─────────────────────
# Seam-approved check lives in .husky/commit-msg (needs commit message).
# Rebase + migration claim work fine here without the message.
git fetch -q origin
BASE=$(git merge-base HEAD origin/main)
if [ "$(git rev-parse origin/main)" != "$BASE" ]; then
  echo "❌ Branch behind origin/main. Rebase before commit."
  exit 1
fi

TOUCHED=$(git diff --cached --name-only)
for f in $(echo "$TOUCHED" | grep '^supabase/migrations/' || true); do
  NUM=$(basename "$f" | grep -oE '^[0-9]+')
  if [ -n "$NUM" ] && ! grep -q "\"$NUM\"" .claude/migration-claims.json 2>/dev/null; then
    echo "❌ Migration $NUM not claimed in .claude/migration-claims.json"
    exit 1
  fi
done

# ─── Multi-window protocol — scope contract ───────────────────────────────
# Verifies every staged file falls within the active window's declared scope
# on the current branch. Bypass: WINDOW_SCOPE_BYPASS=1 git commit ...
node scripts/window-scope-check.mjs

# ─── Vercel cron-count + cadence guard ────────────────────────────────────
# Aborts a commit that would push vercel.json past Hobby plan limits.
# Hobby silently rejects the entire config at validation — no deploy record
# is created. See F-L11 (CLAUDE.md §9) and F-N9 (docs/claude-md/failures.md).
# Bypass: VERCEL_CRON_CHECK_BYPASS=1 git commit ...
node scripts/check-vercel-cron-count.mjs

# ─── F18 compliance gate ──────────────────────────────────────────────────
# Blocks new app/(cockpit)/<X>/page.tsx modules without metrics capture +
# a `// F18: <bench>; <surface>` marker comment. See docs/f18-compliance.md
# for the audit + retrofit roadmap.
# Bypass: F18_CHECK_BYPASS=1 git commit ...
node scripts/check-f18-compliance.mjs

# ─── Resource budget gate ─────────────────────────────────────────────────
# Generalizes the cron-count guard to a registry of file-resident budgets:
# vercel.crons (≤18), package.deps_total (≤300). Externally-synced budgets
# (Vercel env vars, RLS policies) live in the harness_resource_budgets DB
# table and are reconciled by a future sync job. See docs/resource-budgets.md.
# Bypass: BUDGETS_CHECK_BYPASS=1 git commit ...
node scripts/check-budgets.mjs

# Layer 0 — Safety Agent static check (regex-only, ~10ms, no Ollama)
# Blocks destructive SQL / secret writes / force-push patterns in staged diff.
# Bypass: SAFETY_BYPASS=1 git commit ...
node scripts/pre-commit-safety.mjs

# Layer 1 — deterministic checks (zero tokens, fast)
npx lint-staged

# Layer 1.5 — TypeScript type check on src (catches "module not found" + type
# errors that vitest doesn't see — vitest doesn't compile-link the whole graph).
# Triggered by hotfix #111 — a route imported a helper from an unmerged branch
# and reached main because nothing pre-commit was checking the full module graph.
#
# Filters errors under tests/ so pre-existing test typing issues don't block
# commits to src code. Adding a tsconfig.precommit.json that excludes tests/
# is the cleaner long-term move, deferred to a follow-up.
#
# Cost: ~30-40s cold, faster on warm tree.
# Skip with SKIP_TYPECHECK=1 (emergency hotfix only — the gate exists for a reason).
if [ "${SKIP_TYPECHECK}" != "1" ]; then
  ts_errors=$(npx tsc --noEmit 2>&1 | grep -E "^[a-zA-Z]" | grep "error TS" | grep -v "^tests/" || true)
  if [ -n "$ts_errors" ]; then
    echo "❌ TypeScript errors in src code (tests/ excluded):"
    echo "$ts_errors"
    exit 1
  fi
fi

# Layer 2 — AI diff review (Sonnet, ~3-5s)
# Skip if SKIP_AI_REVIEW=1 (e.g. in CI or explicit bypass)
if [ "${SKIP_AI_REVIEW}" != "1" ]; then
  node scripts/ai-review.mjs
fi
