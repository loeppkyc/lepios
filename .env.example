# LepiOS — Environment Variable Reference
# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase (project: lepios, region: ca-central-1)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Stripe
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Telegram (Step 6: orchestrator digest + alerts)
# loeppky_alerts_bot token + chat ID for Night Watchman digest messages.
# Without these, sendMorningDigest() logs telegram_failed in agent_events instead of sending.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama
# OLLAMA_TUNNEL_URL: Cloudflare tunnel URL in production; falls back to localhost.
# Model vars are optional — defaults match what lib/ollama/client.ts expects.
OLLAMA_TUNNEL_URL=http://localhost:11434
OLLAMA_CODE_MODEL=qwen2.5-coder:7b
OLLAMA_ANALYSIS_MODEL=qwen2.5:32b
OLLAMA_GENERAL_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Digital Twin Q&A (app/api/twin/ask)
# OLLAMA_TWIN_MODEL: model for /api/twin/ask; defaults to qwen2.5:32b.
# TWIN_CONFIDENCE_THRESHOLD: float 0-1; below this triggers Claude fallback then escalate.
OLLAMA_TWIN_MODEL=qwen2.5:32b
TWIN_CONFIDENCE_THRESHOLD=0.80

# Oura (v2)
OURA_ACCESS_TOKEN=

# Dropbox (Sprint 4 Chunk D — Statement Coverage Grid)
# OAuth2 refresh token flow. App credentials from Dropbox App Console.
# Same app used by Streamlit OS — copy values from secrets.toml [dropbox] section.
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# Amazon SP-API
AMAZON_SP_REFRESH_TOKEN=
AMAZON_SP_CLIENT_ID=
AMAZON_SP_CLIENT_SECRET=
AMAZON_AWS_ACCESS_KEY=
AMAZON_AWS_SECRET_KEY=
KEEPA_API_KEY=
EBAY_APP_ID=
EBAY_CERT_ID=

# Cron / orchestrator auth
# Protects /api/cron/night-tick, /api/cron/morning-digest, /api/knowledge/nightly.
# Generate with: openssl rand -hex 32
CRON_SECRET=<64-char hex string>

# Anthropic — optional, used by scripts/measure-handoff-tokens.ts for exact
# Claude token counts. Not required for the app to run.
# Never commit a real key — this is for local script use only.
ANTHROPIC_API_KEY=sk-ant-...
